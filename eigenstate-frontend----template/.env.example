# Leave empty during `npm run dev` — Vite proxies /api and /repos to http://127.0.0.1:8080
# Set when the UI is hosted separately from the API (e.g. static CDN):
# VITE_API_URL=http://localhost:8080

# Optional defaults when no repo is registered yet:
# VITE_DEFAULT_OWNER=fastify
# VITE_DEFAULT_REPO=fastify

# Shown on the dashboard status strip:
# VITE_ACTIVE_MODEL=Gemini 1.5 Flash

# Why Explorer: default uses live /api/v1/why. For pitch without backend data:
# VITE_USE_SEED_WHY_ONLY=true
