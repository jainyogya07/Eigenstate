# Eigenstate Environment Variables Example
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Default for Mac local socket: postgresql:///eigenstate
DATABASE_URL=postgresql:///eigenstate

# ── Gemini API (Reasoning Engine) ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GitHub API (Ingestion) ───────────────────────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ── Python intelligence API (Go worker POSTs PR payloads here) ──────────────
# Default matches: cd python && uvicorn api:app --host 127.0.0.1 --port 8000
PYTHON_INTEL_URL=http://127.0.0.1:8000/process

# ── Security ──────────────────────────────────────────────────────────────────
# Secret for JWT authentication in Go API
JWT_SECRET=generate_a_random_string_here
